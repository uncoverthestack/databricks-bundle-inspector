{
  "name": "databricks-bundle-inspector",
  "displayName": "Databricks Bundle Inspector",
  "description": "Inspect and visualize Databricks bundle structure",
  "version": "0.1.1",
  "publisher": "UncoverTheStack",
  "icon": "resources/dark/logo.png",
  "license": "Apache-2.0",
  "type": "module",
  "categories": [
    "Visualization",
    "Notebooks",
    "Data Science",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "databricks",
    "bundle",
    "dab",
    "yaml",
    "jobs",
    "visualization",
    "deployment",
    "inspector"
  ],
  "engines": {
    "vscode": "^1.85.0",
    "node": "22.x"
  },
  "homepage": "https://github.com/uncoverthestack/databricks-bundle-inspector",
  "qna": "https://github.com/uncoverthestack/databricks-bundle-inspector/issues",
  "bugs": {
    "url": "https://github.com/uncoverthestack/databricks-bundle-inspector/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uncoverthestack/databricks-bundle-inspector.git"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "databricksBundleInspector.inspectBundle",
        "title": "Inspect Databricks Bundle",
        "enablement": "resourceFilename =~ /^databricks\\.ya?ml$/"
      },
      {
        "command": "databricksBundleInspector.openBundleIssues",
        "title": "Open Bundle Issues"
      }
    ],
    "configuration": {
      "title": "Databricks Bundle Inspector",
      "properties": {
        "databricksBundleInspector.cliPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to the Databricks CLI executable. When empty, the extension uses databricks from PATH."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "databricksBundleInspector.inspectBundle",
          "group": "navigation",
          "when": "resourceFilename =~ /^databricks\\.ya?ml$/"
        }
      ],
      "editor/context": [
        {
          "command": "databricksBundleInspector.inspectBundle",
          "group": "navigation",
          "when": "resourceFilename =~ /^databricks\\.ya?ml$/"
        }
      ]
    }
  },
  "scripts": {
    "build:ext": "node esbuild.js",
    "build:webview": "node scripts/repair-native-optional-deps.mjs && vite build",
    "build": "npm run build:ext && npm run build:webview",
    "package:vsix": "vsce package --no-dependencies",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "watch-tests": "tsc -p . --outDir out --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "compile": "npm run build:ext",
    "test": "npm run test:unit && npm run test:semantic",
    "test:unit": "jest --testPathIgnorePatterns semanticGraph.test.ts",
    "test:semantic": "jest src/test/unit/extension/semanticGraph.test.ts",
    "test:semantic:cli": "jest --config jest.semantic-cli.config.cjs",
    "test:semantic:cli:matrix": "node scripts/run-semantic-cli-matrix.mjs",
    "verify": "npm run test:unit && npm run test:semantic && npm run typecheck && npm run lint",
    "test:integration:cli": "RUN_REAL_DATABRICKS_CLI_TESTS=1 vscode-test",
    "deps:repair-native": "node scripts/repair-native-optional-deps.mjs",
    "cli:install-matrix": "node scripts/install-databricks-cli-matrix.mjs",
    "fixtures:update:validated-bundle": "node scripts/update-validated-bundle-fixture.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^15.5.2",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "vite": "^8.0.4"
  }
}
