{
  "name": "databricks-bundle-inspector",
  "displayName": "Databricks Bundle Inspector",
  "description": "Inspect and visualize Databricks bundle structure",
  "version": "0.0.1",
  "publisher": "uncoverthestack",
  "license": "Apache-2.0",
  "type": "module",
  "categories": [
    "Visualization",
    "Notebooks",
    "Data Science",
    "Machine Learning",
    "Other"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "qna": "https://github.com/uncoverthestack/databricks-bundle-inspector/issues",
  "bugs": {
    "url": "https://github.com/uncoverthestack/databricks-bundle-inspector/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uncoverthestack/databricks-bundle-inspector.git"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "contributes": {
    "commands": [
      {
        "command": "databricksBundleInspector.inspectBundle",
        "title": "Inspect Databricks Bundle",
        "enablement": "resourceFilename =~ /^databricks\\.ya?ml$/"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "databricksBundleInspector.inspectBundle",
          "group": "navigation",
          "when": "resourceFilename =~ /^databricks\\.ya?ml$/"
        }
      ],
      "editor/context": [
        {
          "command": "databricksBundleInspector.inspectBundle",
          "group": "navigation",
          "when": "resourceFilename =~ /^databricks\\.ya?ml$/"
        }
      ]
    }
  },
  "scripts": {
    "build:ext": "node esbuild.js",
    "build:webview": "vite build",
    "build": "npm run build:ext && npm run build:webview",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "watch-tests": "tsc -p . --outDir out --watch",
    "lint": "eslint .",
    "compile": "npm run build:ext",
    "test": "tsc -p . --outDir out && node --test out/test/bundleContext.test.js out/test/bundleGraph.test.js out/test/jobSelection.test.js out/test/validateBundle.test.js"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.4"
  }
}
