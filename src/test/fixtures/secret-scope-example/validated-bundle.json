{
  "bundle": {
    "name": "secret-scope-example"
  },
  "include": [
    "resources/*.yml"
  ],
  "targets": {
    "dev": {
      "mode": "development",
      "default": true,
      "workspace": {
        "host": "https://example.databricks.com"
      },
      "variables": {
        "warehouse_id": "dev-warehouse-id"
      }
    },
    "prod": {
      "mode": "production",
      "default": true,
      "workspace": {
        "host": "https://example.databricks.com"
      },
      "variables": {
        "warehouse_id": "prod-warehouse-id"
      }
    }
  },
  "variables": {
    "schema": {
      "description": "The schema to use",
      "default": "inspector"
    },
    "catalog": {
      "description": "The catalog to use",
      "default": "development"
    },
    "warehouse_id": {
      "description": "The warehouse to use",
      "default": "general-warehouse-id"
    }
  },
  "resources": {
    "jobs": {
      "config_job": {
        "name": "config_job",
        "trigger": {
          "periodic": {
            "interval": 1,
            "unit": "DAYS"
          }
        },
        "tasks": [
          {
            "task_key": "notebook_task",
            "notebook_task": {
              "notebook_path": "../src/notebook.ipynb",
              "base_parameters": {
                "start_time": "2021-01-01"
              }
            }
          },
          {
            "task_key": "query_file_sql",
            "depends_on": [
              {
                "task_key": "notebook_task"
              }
            ],
            "sql_task": {
              "file": {
                "path": "../src/query_file.sql"
              },
              "warehouse_id": "0123456789"
            }
          },
          {
            "task_key": "query_file_sql_no_extension",
            "sql_task": {
              "file": {
                "path": "../src/query_file_sql_no_extension"
              },
              "warehouse_id": "0123456789"
            }
          }
        ]
      }
    },
    "pipelines": {
      "sample_python_pipeline": {
        "name": "default_python_pipeline",
        "catalog": "${var.catalog}",
        "schema": "${var.schema}",
        "serverless": true,
        "libraries": [
          {
            "glob": {
              "include": "../src/transformations/**"
            }
          }
        ]
      }
    }
  }
}
